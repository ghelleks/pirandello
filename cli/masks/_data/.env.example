# Pirandello — cross-role infrastructure (copy to [base]/.env and merge per-role keys)
# Never commit real values. All keys are optional until a feature needs them.

# Base directory (absolute path). Written by `masks setup --base`.
MASKS_BASE=

# Path to the shared mcp-memory SQLite database file (used by `masks index`).
# Default when unset: ~/.pirandello/memory.db (created by masks setup if missing).
MCP_MEMORY_DB_PATH=

# Override Pirandello framework root (hooks, guards, AGENTS.md source).
# If unset, `masks` uses the _data/ directory bundled inside the installed package.
PIRANDELLO_ROOT=

# Optional: full shell command for heartbeat LLM (default: claude --print --output-format text).
MASKS_LLM_CMD=

# Optional: command for interactive add-role (split with shlex).
MASKS_INTERACTIVE_CMD=

# ── Google Workspace (gws CLI) ──────────────────────────────────────────────
# Short account label used by `gws --account` for work and personal contexts.
GWS_ACCOUNT_WORK=
GWS_ACCOUNT_PERSONAL=

# Gmail OAuth refresh token for programmatic mail access (work account).
GMAIL_REFRESH_TOKEN=

# ── Todoist ─────────────────────────────────────────────────────────────────
TODOIST_API_TOKEN=

# ── WorkBoard ───────────────────────────────────────────────────────────────
WORKBOARD_API_KEY=

# ── Feedly ──────────────────────────────────────────────────────────────────
FEEDLY_AUTH_TOKEN=

# ── GitLab ──────────────────────────────────────────────────────────────────
GITLAB_TOKEN=

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
