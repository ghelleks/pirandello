# Pirandello — cross-role infrastructure (copy to [base]/.env and merge per-role keys)
# Never commit real values. All keys are optional until a feature needs them.

# Base directory (absolute path). Written by `masks setup --base`.
MASKS_BASE=

# Path to the shared mcp-memory SQLite database file (used by `masks index`).
# Default when unset: ~/.pirandello/memory.db (created by masks setup if missing).
MCP_MEMORY_DB_PATH=

# Override Pirandello framework root (hooks, templates, AGENTS.md source).
# If unset, `masks` uses the _data/ directory bundled inside the installed package.
PIRANDELLO_ROOT=

# Optional: command for interactive add-role (split with shlex).
MASKS_INTERACTIVE_CMD=

# ── Google Calendar / Gmail (gws CLI) — interactive sessions & skills ───────
# Install the **gws** CLI and complete its OAuth flow for each account you use.
# Each Role sets `GWS_PROFILE` in `[role]/.env` (see `templates/role.env.example`).
# Pirandello does not store Google refresh tokens.

# ── Optional: agents & skills (not read by the masks Python package) ─────────
# TODOIST_API_TOKEN=
# WORKBOARD_API_KEY=
# GITLAB_TOKEN=
# GITHUB_TOKEN=   # e.g. for `gh` when using `masks reflect`
