# Pirandello — per-role overrides ([role]/.env). Never commit real values.
# Key catalog: keep in sync with skills/mask-add-role/SKILL.md.

MASKS_BASE=

# gws CLI account label (`gws --account "$GWS_PROFILE"`). OAuth tokens are stored by gws in its own config, not in this file.
GWS_PROFILE=

MCP_MEMORY_DB_PATH=

# Override Pirandello framework root (hooks, templates, AGENTS.md source).
PIRANDELLO_ROOT=

# Optional: command for interactive add-role (split with shlex).
MASKS_INTERACTIVE_CMD=

# ── Todoist ─────────────────────────────────────────────────────────────────
TODOIST_API_TOKEN=

# ── WorkBoard ───────────────────────────────────────────────────────────────
WORKBOARD_API_KEY=

# ── GitLab ──────────────────────────────────────────────────────────────────
GITLAB_TOKEN=

# ── GitHub ──────────────────────────────────────────────────────────────────
GITHUB_TOKEN=
